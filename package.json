{
  "name": "@naxit/comete-icons",
  "version": "0.3.5",
  "description": "Comète icon library — React components with design token color support",
  "author": "naxit",
  "license": "CC0-1.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naxit/comete-icons.git"
  },
  "keywords": [
    "icons",
    "react",
    "svg",
    "design-system",
    "comete"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "figma:sync": "tsx scripts/fetch-icons.ts",
    "figma:test": "tsx scripts/fetch-test.ts",
    "optimize": "tsx scripts/optimize-svg.ts",
    "generate": "tsx scripts/generate-components.ts",
    "pipeline": "pnpm figma:sync && pnpm optimize && pnpm generate && pnpm build",
    "build": "tsup",
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "svgo": "^3.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./styles": "./dist/icons.css"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ],
      "icons/*": [
        "dist/icons/*.d.ts"
      ]
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
